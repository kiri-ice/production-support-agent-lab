    "case_id": "tool_missing_order_001",
    "scenario": "Known customer asks about shipping without giving an order id; the agent should search candidate orders and ask for confirmation instead of fabricating tracking status.",
    "locale": "en-US",
    "user_id": "user_demo",
    "turns": [
      {
        "role": "user",
        "content": "Where is my package shipping?"
      }
