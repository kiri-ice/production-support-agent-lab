    "expected": {
      "intent": "order_status",
      "required_tools": ["crm.get_customer", "order.search"],
      "must_not_include": ["YT99887766CN", "Package arrived"],
      "escalation": false,
      "policy_refs": ["shipping_policy_v2"]
    },
    "tags": ["tool_failure", "missing_slot", "regression"]
  },
  {
    "case_id": "tool_order_not_found_001",
